  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    /* ── THEME TOKENS ── */
    :root {
      /* Light (Option D — default) */
      --bg:         #F8F6FF;
      --bg2:        #EFEBFF;
      --card:       #FFFFFF;
      --card-h:     #F3EFFE;
      --border:     rgba(120,80,220,0.14);
      --border-h:   rgba(120,80,220,0.36);

      --p1:         #7B50DC;
      --p2:         #5530A8;
      --a1:         #7B50DC;
      --a2:         #5530A8;
      --a3:         #9B78E8;
      --glow:       rgba(123,80,220,0.18);

      --td:         #1A1035;
      --tmd:        #4A3870;
      --tfd:        #9888C0;

      --tag-bg:     rgba(123,80,220,0.10);
      --tag-bd:     rgba(123,80,220,0.28);
      --tag-txt:    #5530A8;
      --tag2-bd:    rgba(123,80,220,0.18);
      --tag2-txt:   #6A50A0;

      --tk-bg:      rgba(123,80,220,0.07);
      --stat-bg:    rgba(123,80,220,0.06);
      --prog-bg:    rgba(123,80,220,0.10);

      --toggle-bg:  #EDE8FF;
      --toggle-ico: #7B50DC;

      --shadow:     0 4px 24px rgba(60,30,120,0.10);
      --shadow-h:   0 12px 40px rgba(60,30,120,0.16);
      --r: 16px;
    }

    [data-theme="dark"] {
      --bg:         #120E2E;
      --bg2:        #1A1540;
      --card:       #180F38;
      --card-h:     #221848;
      --border:     rgba(200,130,255,0.14);
      --border-h:   rgba(200,130,255,0.36);

      --p1:         #C882FF;
      --p2:         #9040C8;
      --a1:         #C882FF;
      --a2:         #E0C0FF;
      --a3:         #D8A8FF;
      --glow:       rgba(200,130,255,0.20);

      --td:         #F0ECFF;
      --tmd:        #A090C8;
      --tfd:        #5A4880;

      --tag-bg:     rgba(200,130,255,0.14);
      --tag-bd:     rgba(200,130,255,0.32);
      --tag-txt:    #C882FF;
      --tag2-bd:    rgba(200,130,255,0.20);
      --tag2-txt:   #9880B8;

      --tk-bg:      rgba(200,130,255,0.08);
      --stat-bg:    rgba(200,130,255,0.07);
      --prog-bg:    rgba(200,130,255,0.10);

      --toggle-bg:  #2A1850;
      --toggle-ico: #C882FF;

      --shadow:     0 4px 24px rgba(0,0,0,0.40);
      --shadow-h:   0 12px 44px rgba(0,0,0,0.50);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      color: var(--td);
      line-height: 1.72;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      overflow-x: hidden;
      transition: background 0.35s, color 0.35s;
    }

    /* Subtle dot grid */
    body::before {
      content: '';
      position: fixed; inset: 0;
      pointer-events: none; z-index: 0;
      background-image: radial-gradient(circle, rgba(123,80,220,0.07) 1px, transparent 1px);
      background-size: 36px 36px;
      transition: opacity 0.35s;
    }
    [data-theme="dark"] body::before {
      background-image: radial-gradient(circle, rgba(200,130,255,0.06) 1px, transparent 1px);
    }

    /* Orbs — dark only */
    .orb { position: fixed; border-radius: 50%; filter: blur(120px); pointer-events: none; z-index: 0; opacity: 0; transition: opacity 0.5s; }
    [data-theme="dark"] .orb { opacity: 1; }
    .o1 { width: 600px; height: 600px; background: #7B50DC; opacity: 0; top: -180px; right: -140px; }
    .o2 { width: 400px; height: 400px; background: #3B0764; opacity: 0; bottom: 80px; left: -100px; }
    [data-theme="dark"] .o1 { opacity: 0.11; }
    [data-theme="dark"] .o2 { opacity: 0.10; }

    /* ── ANIMATIONS ── */
    @keyframes fu { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:none; } }
    .anim { animation: fu 0.6s ease backwards; }

    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(248,246,255,0.92);
      backdrop-filter: blur(24px);
      border-bottom: 1px solid var(--border);
      transition: background 0.35s, border-color 0.35s;
    }
    [data-theme="dark"] nav { background: rgba(18,14,46,0.92); }
    .ni {
      max-width: 1080px; margin: 0 auto;
      padding: 0 28px; height: 66px;
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
    }
    .nl { display: flex; align-items: center; gap: 12px; }
    .logo {
      width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
      background: linear-gradient(135deg, var(--p1), var(--p2));
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem; font-weight: 700; color: #fff;
      box-shadow: 0 0 16px var(--glow);
    }
    .lname {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.08rem; font-weight: 600; color: var(--td);
      letter-spacing: 0.01em;
    }
    .ntag {
      font-size: 0.58rem; font-weight: 700;
      letter-spacing: 0.13em; text-transform: uppercase;
      color: var(--a1);
      background: var(--tag-bg);
      border: 1px solid var(--tag-bd);
      padding: 3px 10px; border-radius: 100px;
    }
    .nr { display: flex; align-items: center; gap: 10px; }

    /* Toggle */
    .toggle-btn {
      display: flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: 9px;
      background: var(--toggle-bg);
      border: 1px solid var(--border);
      cursor: pointer; transition: all 0.2s;
      color: var(--toggle-ico);
    }
    .toggle-btn:hover { border-color: var(--border-h); }
    .toggle-btn svg { width: 16px; height: 16px; flex-shrink: 0; transition: opacity 0.2s; }
    .icon-moon { display: block; }
    .icon-sun  { display: none; }
    [data-theme="dark"] .icon-moon { display: none; }
    [data-theme="dark"] .icon-sun  { display: block; }

    /* LinkedIn button */
    .li-btn {
      display: flex; align-items: center; gap: 7px;
      background: rgba(10,102,194,0.10);
      border: 1px solid rgba(10,102,194,0.28);
      color: #1A66C2; padding: 7px 16px;
      border-radius: 9px; font-size: 0.76rem; font-weight: 600;
      text-decoration: none; transition: all 0.2s; letter-spacing: 0.02em;
      white-space: nowrap;
    }
    [data-theme="dark"] .li-btn { color: #7BB8F0; background: rgba(10,102,194,0.12); }
    .li-btn:hover { background: rgba(10,102,194,0.18); border-color: rgba(10,102,194,0.5); }

    /* ── HERO ── */
    .hero {
      position: relative; z-index: 1;
      max-width: 1080px; margin: 0 auto;
      padding: 88px 28px 64px;
    }
    .eyebrow {
      display: inline-flex; align-items: center; gap: 12px;
      font-size: 0.65rem; font-weight: 700;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--a1); margin-bottom: 26px;
    }
    .eline { display: block; width: 28px; height: 1.5px; background: var(--a1); border-radius: 2px; opacity: 0.6; }

    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3rem, 7vw, 5.6rem);
      font-weight: 300; line-height: 1.0;
      letter-spacing: -0.02em; color: var(--td);
      margin-bottom: 8px;
    }
    h1 .gr {
      font-style: italic;
      background: linear-gradient(135deg, var(--a1) 0%, var(--a3) 60%, var(--p2) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hsub {
      font-size: 1.13rem; font-weight: 300;
      color: var(--tmd); margin-bottom: 36px;
      line-height: 1.7; max-width: 560px;
    }

    .hchips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 44px; }
    .hchip {
      display: flex; align-items: center; gap: 6px;
      font-size: 0.78rem; font-weight: 500; color: var(--tmd);
      background: var(--stat-bg);
      border: 1px solid var(--border);
      padding: 7px 15px; border-radius: 100px;
      transition: border-color 0.2s;
    }
    .hchip svg { color: var(--a1); flex-shrink: 0; }

    /* Stats */
    .stats {
      display: grid; grid-template-columns: repeat(4,1fr);
      border: 1px solid var(--border); border-radius: var(--r);
      overflow: hidden; box-shadow: var(--shadow);
    }
    .sblk {
      padding: 24px 18px; text-align: center;
      background: var(--stat-bg);
      border-right: 1px solid var(--border);
      transition: background 0.2s;
    }
    .sblk:last-child { border-right: none; }
    .sblk:hover { background: var(--card-h); }
    .snum {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.6rem; font-weight: 700; line-height: 1;
      background: linear-gradient(135deg, var(--a1), var(--a3));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; margin-bottom: 5px;
    }
    .slbl {
      font-size: 0.62rem; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase; color: var(--tfd);
    }

    /* ── PROGRESS ── */
    .pw {
      position: relative; z-index: 1;
      max-width: 1080px; margin: 0 auto;
      padding: 0 28px 56px;
    }
    .ph { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px; }
    .pl { font-size: 0.63rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--tfd); }
    .pp { font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-weight: 600; color: var(--a1); }
    .pt { height: 4px; background: var(--prog-bg); border-radius: 2px; overflow: hidden; }
    .pf {
      height: 100%; width: 0%;
      background: linear-gradient(90deg, var(--p2), var(--a1));
      border-radius: 2px;
      transition: width 1.4s cubic-bezier(0.4,0,0.2,1);
      box-shadow: 0 0 8px var(--glow);
    }

    /* ── SECTION TITLE ── */
    .secw {
      position: relative; z-index: 1;
      max-width: 1080px; margin: 0 auto;
      padding: 0 28px 22px;
    }
    .sectitle {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem; font-weight: 400; font-style: italic;
      color: var(--tmd);
      display: flex; align-items: center; gap: 16px;
    }
    .sectitle::after {
      content: ''; flex: 1; height: 1px;
      background: linear-gradient(90deg, var(--border), transparent);
    }

    /* ── BADGE SHELF ── */
    .bw {
      position: relative; z-index: 1;
      max-width: 1080px; margin: 0 auto;
      padding: 0 28px 60px;
    }
    .bshelf { display: flex; gap: 14px; overflow-x: auto; padding-bottom: 8px; scrollbar-width: none; }
    .bshelf::-webkit-scrollbar { display: none; }
    .bitem {
      flex-shrink: 0; display: flex; flex-direction: column;
      align-items: center; gap: 6px;
      animation: fu 0.45s ease backwards;
    }
    .bimg { width: 58px; height: 58px; }
    .bimg img { width: 100%; height: 100%; object-fit: contain; }
    .bday { font-size: 0.54rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--tfd); }

    /* ── CARDS GRID ── */
    .jw {
      position: relative; z-index: 1;
      max-width: 1080px; margin: 0 auto;
      padding: 0 28px 80px;
    }
    .jgrid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(318px,1fr));
      gap: 16px;
    }

    .dcard {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--r);
      overflow: hidden; position: relative;
      transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s, background 0.35s;
      animation: fu 0.55s ease backwards;
      box-shadow: var(--shadow);
    }
    .dcard::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, transparent, var(--a1), transparent);
      opacity: 0; transition: opacity 0.3s;
    }
    .dcard:hover { transform: translateY(-4px); border-color: var(--border-h); box-shadow: var(--shadow-h); }
    .dcard:hover::before { opacity: 1; }

    .ch { padding: 22px 22px 0; display: flex; gap: 14px; align-items: flex-start; }
    .dayno {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem; font-weight: 700; line-height: 1;
      color: var(--border-h); flex-shrink: 0;
      width: 50px; text-align: right; margin-top: -2px;
      transition: color 0.35s;
    }
    .cta-wrap { flex: 1; min-width: 0; }
    .cdate { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--tfd); margin-bottom: 4px; }
    .ctitle { font-family: 'Cormorant Garamond', serif; font-size: 1.18rem; font-weight: 600; line-height: 1.24; color: var(--td); }

    .cb { padding: 14px 22px 22px; }
    .csummary { font-size: 0.92rem; font-weight: 400; color: var(--tmd); line-height: 1.75; margin-bottom: 15px; }

    .tags { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 9px; }
    .ttool {
      font-size: 0.63rem; font-weight: 700; letter-spacing: 0.05em;
      background: var(--tag-bg); border: 1px solid var(--tag-bd);
      color: var(--tag-txt); padding: 4px 10px; border-radius: 5px; text-transform: uppercase;
    }
    .tconcept {
      font-size: 0.63rem; font-weight: 500;
      background: transparent; border: 1px solid var(--tag2-bd);
      color: var(--tag2-txt); padding: 4px 10px; border-radius: 5px;
    }

    .takeaway {
      margin-top: 14px; padding: 13px 15px;
      background: var(--tk-bg);
      border-left: 2.5px solid var(--a1);
      border-radius: 0 8px 8px 0;
    }
    .tklbl { font-size: 0.56rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--a1); opacity: 0.8; margin-bottom: 5px; }
    .tktxt { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-style: italic; color: var(--td); line-height: 1.6; }

    .proj-link {
      display: inline-flex; align-items: center; gap: 7px;
      margin-top: 15px; padding: 8px 16px;
      font-size: 0.76rem; font-weight: 600; letter-spacing: 0.03em;
      color: var(--a1); background: var(--tag-bg);
      border: 1px solid var(--tag-bd); border-radius: 9px;
      text-decoration: none; transition: all 0.2s;
    }
    .proj-link:hover { background: var(--card-h); border-color: var(--a1); transform: translateX(3px); }

    /* ── TOOLS CLOUD ── */
    .tw {
      position: relative; z-index: 1;
      max-width: 1080px; margin: 0 auto;
      padding: 0 28px 80px;
    }
    .tcloud { display: flex; flex-wrap: wrap; gap: 8px; }
    .tchip {
      font-size: 0.72rem; font-weight: 500;
      background: var(--stat-bg); border: 1px solid var(--border);
      color: var(--tmd); padding: 6px 14px; border-radius: 100px;
      transition: all 0.2s;
    }
    .tchip:hover { border-color: var(--border-h); color: var(--a1); background: var(--card-h); }

    /* ── FOOTER ── */
    footer {
      position: relative; z-index: 1;
      border-top: 1px solid var(--border);
      padding: 34px 28px;
      background: var(--bg);
      transition: background 0.35s;
    }
    .fi {
      max-width: 1080px; margin: 0 auto;
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 14px;
    }
    .fb { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 600; color: var(--td); }
    .fn { font-size: 0.72rem; color: var(--tfd); margin-top: 2px; }
    .btt {
      display: flex; align-items: center; gap: 7px;
      font-size: 0.72rem; font-weight: 500; color: var(--tmd);
      text-decoration: none; padding: 8px 16px;
      border: 1px solid var(--border); border-radius: 9px; transition: all 0.2s;
    }
    .btt:hover { border-color: var(--border-h); color: var(--a1); }

    /* ── RESPONSIVE ── */
    @media (max-width: 680px) {
      .hero, .pw, .secw, .bw, .jw, .tw { padding-left: 18px; padding-right: 18px; }
      .hero { padding-top: 60px; }
      h1 { font-size: 2.8rem; }
      .stats { grid-template-columns: repeat(2,1fr); }
      .sblk:nth-child(2) { border-right: none; }
      .sblk:nth-child(3) { border-right: 1px solid var(--border); border-top: 1px solid var(--border); }
      .sblk:nth-child(4) { border-top: 1px solid var(--border); }
      .jgrid { grid-template-columns: 1fr; }
      .ntag, .lname { display: none; }
      .ni { padding: 0 18px; }
    }
  </style>
</head>
